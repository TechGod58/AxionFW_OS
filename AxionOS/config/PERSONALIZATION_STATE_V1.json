{
    "version":  2,
    "theme":  "light",
    "accent_mode":  "manual",
    "accent":  "aero_blue",
    "wallpaper_pack":  "Axion Classic",
    "desktop_icons":  {
                          "profileFolder":  true,
                          "mainDrive":  true,
                          "recycleBin":  true
                      },
    "taskbar_alignment":  "left",
