    "windows": {
      "extensions": [
        ".exe",
        ".msi",
        ".msix",
        ".appx",
        ".cmd",
        ".bat"
      ],
      "profiles": [
        "win95",
        "win98",
        "winme",
        "win2000",
        "winxp",
        "vista",
        "win7",
        "win8",
        "win81",
        "win10",
        "win11"
      ]
    },
    "linux": {
      "extensions": [
        ".deb",
        ".rpm",
        ".pkg.tar",
        ".pkg.tar.zst",
        ".run",
        ".appimage",
        ".flatpak",
        ".snap",
        ".tar.gz",
        ".tar.xz"
      ],
      "profiles": [
        "linux_2_0",
        "linux_2_2",
        "linux_2_4",
        "linux_2_6",
        "linux_3_x",
        "linux_4_x",
        "linux_5_x",
        "linux_current"
      ]
    }
  }
}

