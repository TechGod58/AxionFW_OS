      "pathSegment": "Videos",
      "windowsBehavior": "videos",
      "reactsLike": "ms_windows_known_folder",
      "sandboxKind": "persistent_profile_sandbox",
      "neverDestroyOnClose": true,
      "supportsProperties": true,
      "supportsLeftClick": true,
      "supportsRightClick": true
    },
    "workspace": {
      "displayName": "Workspace",
      "legacyAlias": "Desktop",
      "pathSegment": "Workspace",
      "windowsBehavior": "desktop",
      "reactsLike": "ms_windows_known_folder",
      "sandboxKind": "persistent_profile_sandbox",
      "neverDestroyOnClose": true,
