{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axion.local/schemas/axionos_bus_contract_v1.schema.json",
  "title": "AxionOS Bus Contract v1",
  "type": "object",
  "required": ["v", "type", "id", "ts", "source", "target", "corr", "payload"],
  "properties": {
    "v": { "const": 1 },
    "type": {
      "type": "string",
      "enum": [
        "component.register",
        "component.registered",
        "component.rejected",
        "component.heartbeat",
        "component.capability.update",
        "route.request",
        "route.assigned",
        "route.denied",
        "component.fault",
        "component.quarantine",
        "ig.verdict"
      ]
    },
    "id": { "type": "string", "minLength": 1 },
    "ts": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "corr": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "component.register" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["component_id", "component_kind", "contract_version", "capabilities"],
            "properties": {
              "component_id": { "type": "string" },
              "component_kind": { "type": "string", "enum": ["vm", "service", "driver", "worker"] },
              "contract_version": { "type": "string" },
              "capabilities": { "type": "array", "items": { "type": "string" } },
              "resource_hints": {
                "type": "object",
                "properties": {
                  "cpu": { "type": "integer", "minimum": 1 },
                  "mem_mb": { "type": "integer", "minimum": 1 }
                },
                "additionalProperties": true
              },
              "labels": { "type": "object", "additionalProperties": { "type": "string" } }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "component.heartbeat" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["component_id", "state", "health"],
            "properties": {
              "component_id": { "type": "string" },
              "state": { "type": "string", "enum": ["warmed", "active", "degraded", "quarantined"] },
              "health": {
                "type": "object",
                "required": ["ok"],
                "properties": {
                  "ok": { "type": "boolean" },
                  "score": { "type": "number", "minimum": 0, "maximum": 1 }
                },
                "additionalProperties": true
              },
              "metrics": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "route.request" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["job_id", "workload_class", "requirements"],
            "properties": {
              "job_id": { "type": "string" },
              "workload_class": {
                "type": "string",
                "enum": ["latency_sensitive", "stability_critical", "throughput_heavy"]
              },
              "requirements": { "type": "array", "items": { "type": "string" } },
              "safety_profile": { "type": "string" },
              "deadline_ms": { "type": "integer", "minimum": 1 },
              "input_ref": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "component.fault" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["component_id", "severity", "code"],
            "properties": {
              "component_id": { "type": "string" },
              "severity": { "type": "string", "enum": ["warn", "error", "critical"] },
              "code": { "type": "string" },
              "detail": { "type": "string" },
              "telemetry_ref": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "component.quarantine" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["component_id", "reason", "ttl_sec"],
            "properties": {
              "component_id": { "type": "string" },
              "reason": { "type": "string" },
              "ttl_sec": { "type": "integer", "minimum": 1 },
              "allow_rejoin": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "ig.verdict" } } },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["verdict", "policy_id", "reason"],
            "properties": {
              "verdict": { "type": "string", "enum": ["pass", "warn", "fail"] },
              "policy_id": { "type": "string" },
              "rule_hits": { "type": "array", "items": { "type": "string" } },
              "reason": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
