{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AxionOS FW handoff schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["platform_id","fw_version","handoff_contract_version","memory_map","boot_vector","timestamp_utc"],
  "properties": {
    "platform_id": { "type": "string", "minLength": 1 },
    "fw_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?([\\-\\+].+)?$" },
    "handoff_contract_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "timestamp_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "boot_vector": { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]+$" },
    "memory_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["base", "size"],
        "properties": {
          "base": { "oneOf": [ { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]+$" }, { "type": "integer", "minimum": 0 } ] },
          "size": { "oneOf": [ { "type": "string", "pattern": "^(0x)?[0-9a-fA-F]+$" }, { "type": "integer", "minimum": 1 } ] },
          "type": { "type": "string" },
          "flags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
