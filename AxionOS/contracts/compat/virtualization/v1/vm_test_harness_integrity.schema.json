{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vm_test_harness_integrity schema",
  "type": "object",
  "required": [
    "status",
    "audit_path",
    "smoke_path",
    "failures",
    "vm_config_path",
    "vm_definition_hash",
    "snapshot_chain_hash",
    "checks"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "audit_path": {
      "type": "string"
    },
    "smoke_path": {
      "type": "string"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "vm_config_path": {
      "type": "string"
    },
    "vm_definition_hash": {
      "type": "string"
    },
    "snapshot_chain_hash": {
      "type": "string"
    },
    "checks": {
      "type": "object",
      "required": [
        "boot",
        "snapshot_restore",
        "network_isolation",
        "determinism"
      ],
      "properties": {
        "boot": {
          "type": "boolean"
        },
        "snapshot_restore": {
          "type": "boolean"
        },
        "network_isolation": {
          "type": "boolean"
        },
        "determinism": {
          "type": "boolean"
        }
      }
    }
  }
}
